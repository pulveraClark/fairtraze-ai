generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

enum SystemRole {
  ADMIN
  INSTRUCTOR
  STUDENT
}

enum SourceType {
  GITHUB
  EDITOR
  COMBINED
}

enum MembershipRole {
  LEADER
  MEMBER
}

enum ClassType {
  LECTURE
  LABORATORY
}

enum AlertType {
  HIGH_RISK
  MODERATE_RISK
  MEMBER_FLAGGED
}

model User {
  id               Int               @id @default(autoincrement())
  email            String            @unique
  passwordHash     String
  name             String
  systemRole       SystemRole        @default(STUDENT)
  githubUsername   String?
  createdAt        DateTime          @default(now())
  classSections    ClassSection[]
  groupMemberships GroupMembership[]
  alerts           Alert[]
}

model ClassSection {
  id           Int          @id @default(autoincrement())
  subjectCode  String
  subjectName  String
  course       String       @default("BSIT")
  edpCode      String       @default("")
  type         ClassType    @default(LECTURE)
  instructorId Int
  createdAt    DateTime     @default(now())
  instructor   User         @relation(fields: [instructorId], references: [id])
  assignments  Assignment[]

  @@unique([instructorId, edpCode])
}

model Assignment {
  id             Int          @id @default(autoincrement())
  classSectionId Int
  title          String
  deadline       DateTime?
  maxGroupSize   Int          @default(5)
  sourceType     SourceType   @default(GITHUB)
  joinCode       String       @unique
  createdAt      DateTime     @default(now())
  classSection   ClassSection @relation(fields: [classSectionId], references: [id], onDelete: Cascade)
  projects       Project[]
}

model GroupMembership {
  id        Int            @id @default(autoincrement())
  userId    Int
  projectId Int
  role      MembershipRole @default(MEMBER)
  joinedAt  DateTime       @default(now())
  user      User           @relation(fields: [userId], references: [id])
  project   Project        @relation(fields: [projectId], references: [id], onDelete: Cascade)

  @@unique([userId, projectId])
}

model Project {
  id                   Int               @id @default(autoincrement())
  groupName            String            @default("")   // student team name, e.g. "Group 1"
  name                 String                            // app/project name, e.g. "FairTraze AI"
  repoUrl              String                            // GitHub repository URL
  assignmentLabel      String            @default("")   // fallback display string, e.g. "CC-APPSDEV22 — Applications Development"
  assignmentId         Int?
  membershipChangedAt  DateTime?                         // updated when members join or leave; used to detect stale reports
  createdAt            DateTime          @default(now())
  assignment           Assignment?       @relation(fields: [assignmentId], references: [id], onDelete: Cascade)
  members              Member[]
  reports              Report[]
  groupMemberships     GroupMembership[]
  alerts               Alert[]
}

model Member {
  id             Int     @id @default(autoincrement())
  projectId      Int
  studentName    String
  githubUsername String
  project        Project @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model Report {
  id          Int      @id @default(autoincrement())
  projectId   Int
  generatedAt DateTime @default(now())
  gini        Float?
  teamHealth  String?
  content     String?
  project     Project  @relation(fields: [projectId], references: [id], onDelete: Cascade)
}

model Alert {
  id           Int       @id @default(autoincrement())
  projectId    Int
  instructorId Int
  type         AlertType
  message      String
  teamHealth   String
  read         Boolean   @default(false)
  createdAt    DateTime  @default(now())
  project      Project   @relation(fields: [projectId], references: [id], onDelete: Cascade)
  instructor   User      @relation(fields: [instructorId], references: [id])
}
