generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

model Project {
  id        Int      @id @default(autoincrement())
  name      String
  repoUrl   String
  createdAt DateTime @default(now())
  members   Member[]
  reports   Report[]
}

model Member {
  id             Int     @id @default(autoincrement())
  projectId      Int
  studentName    String
  githubUsername String
  project        Project @relation(fields: [projectId], references: [id])
}

model Report {
  id          Int      @id @default(autoincrement())
  projectId   Int
  generatedAt DateTime @default(now())
  gini        Float?
  teamHealth  String?
  content     String?
  project     Project  @relation(fields: [projectId], references: [id])
}
